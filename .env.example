# ── AI Provider ───────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
LLM_MODEL=gemini-2.5-flash
LLM_PROVIDER=google_genai
TEXT_EMBEDDING_MODEL=models/text-embedding-004

# ── Paths (relative to repo root for local dev) ───────────────────────────────
PDF_FOLDER_PATH=documents/pdf
VECTOR_DB_PATH=vector_db/faiss_index
WHO_DOCS_PATH=documents/who
WHO_DATA_PATH=data/who
DATA_DIR=data

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is fine for local dev. For Cloud Run production use Cloud SQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@/dbname?host=/cloudsql/project:region:instance
DATABASE_URL=sqlite:///./data/app.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=20160

# ── Cloud Run Deployment ──────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=asia-southeast1
SERVICE_NAME=baby-health-assistant
ARTIFACT_REPO=baby-health-assistant

# Cloud Run resource limits
CLOUD_RUN_PORT=8080
CLOUD_RUN_MEMORY=1Gi
CLOUD_RUN_CPU=1
CLOUD_RUN_TIMEOUT=300
